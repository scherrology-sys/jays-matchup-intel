<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jays Matchup Intel Retro 3-30-26</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:       #003E7E;
    --navy-dark:  #002050;
    --navy-mid:   #004fa3;
    --panel:      #071e3d;
    --red:        #E8002D;
    --white:      #FFFFFF;
    --cream:      #e8f0f8;
    --gold:       #C4A24B;
    --text-dim:   #7a9cc0;
    --border:     rgba(255,255,255,0.08);
    --success:    #2dd4a0;
    --warning:    #f4b942;
    --danger:     #ff4f6a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--navy-dark);
    color: var(--white);
    font-family: 'IBM Plex Sans', sans-serif;
    min-height: 100vh;
  }

  /* BACK NAV */
  .back-nav {
    background: #000d22;
    border-bottom: 1px solid var(--border);
    padding: 7px 24px;
  }
  .back-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--white); }
  .back-link span { color: var(--red); font-size: 12px; }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, var(--navy-dark) 0%, #001a40 50%, var(--navy-dark) 100%);
    border-bottom: 2px solid var(--gold);
    padding: 20px 32px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg, transparent, transparent 60px,
      rgba(255,255,255,0.012) 60px, rgba(255,255,255,0.012) 61px
    );
    pointer-events: none;
  }
  .header-left { display: flex; flex-direction: column; gap: 3px; }
  .header-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .header-title {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--white);
  }
  .header-title span { color: var(--red); }
  .header-sub {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    margin-top: 2px;
  }
  .header-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .score-box {
    background: rgba(7,30,61,0.9);
    border: 1px solid rgba(196,162,75,0.3);
    border-left: 3px solid var(--gold);
    border-radius: 3px;
    padding: 8px 14px;
    text-align: center;
  }
  .score-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .score-val {
    font-family: 'Oswald', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--danger);
    letter-spacing: 0.06em;
    line-height: 1;
  }
  .score-note {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    color: var(--text-dim);
    margin-top: 3px;
  }
  .aca-tag {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(7,30,61,0.94);
    border: 1px solid rgba(232,0,45,0.35);
    border-left: 3px solid var(--red);
    border-radius: 3px;
    padding: 9px 13px 9px 10px;
  }
  .aca-text { display: flex; flex-direction: column; gap: 3px; }
  .aca-name {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--white);
    line-height: 1;
  }
  .aca-handle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: var(--text-dim);
    line-height: 1;
  }

  /* TABS */
  .tab-bar {
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    display: flex;
    padding: 0 20px;
    overflow-x: auto;
  }
  .tab-bar::-webkit-scrollbar { height: 0; }
  .tab {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 12px 18px;
    color: var(--text-dim);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .tab:hover { color: var(--white); }
  .tab.active { color: var(--white); border-bottom-color: var(--gold); }

  /* PANELS */
  .panel-wrap { padding: 24px 24px 40px; }
  .panel { display: none; }
  .panel.active { display: block; }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .section-title {
    font-family: 'Oswald', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .section-title em { font-style: normal; color: var(--gold); }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 18px;
  }
  .card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .divider { height: 1px; background: var(--border); margin: 18px 0; }

  /* ARSENAL ROW */
  .arsenal-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .ar-name {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--cream);
    width: 130px;
    flex-shrink: 0;
  }
  .ar-bars {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .ar-bar-row {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 10px;
  }
  .ar-bar-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 7px;
    color: var(--text-dim);
    width: 32px;
    flex-shrink: 0;
  }
  .ar-bar-track {
    flex: 1;
    height: 8px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }
  .ar-bar-fill {
    height: 100%;
    border-radius: 2px;
  }
  .ar-pct {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    width: 36px;
    text-align: right;
    flex-shrink: 0;
  }
  .ar-delta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    width: 48px;
    text-align: right;
    flex-shrink: 0;
  }

  /* MODEL SCORECARD ROW */
  .score-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    padding: 9px 12px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 3px;
    position: relative;
    overflow: hidden;
  }
  .score-row::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }
  .score-row.win::before { background: var(--success); }
  .score-row.miss::before { background: var(--danger); }
  .score-row.push::before { background: var(--text-dim); }
  .score-row.nomodel::before { background: var(--gold); }

  .sr-name {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--cream);
    width: 160px;
    flex-shrink: 0;
  }
  .sr-outcomes {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: var(--text-dim);
    width: 160px;
    flex-shrink: 0;
  }
  .sr-bar-track {
    flex: 1;
    height: 14px;
    background: rgba(255,255,255,0.04);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }
  .sr-bar-pred {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    border-radius: 2px;
    opacity: 0.3;
  }
  .sr-bar-actual {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    border-radius: 2px;
    opacity: 0.85;
  }
  .sr-woba-pred {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    width: 44px;
    text-align: right;
    flex-shrink: 0;
  }
  .sr-arrow {
    font-size: 11px;
    color: var(--text-dim);
    flex-shrink: 0;
  }
  .sr-woba-actual {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    width: 44px;
    text-align: right;
    flex-shrink: 0;
  }
  .sr-delta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    width: 52px;
    text-align: right;
    flex-shrink: 0;
  }
  .sr-verdict {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 2px;
    width: 58px;
    text-align: center;
    flex-shrink: 0;
  }
  .sr-verdict.win { background: rgba(45,212,160,0.12); color: var(--success); border: 1px solid rgba(45,212,160,0.3); }
  .sr-verdict.miss { background: rgba(255,79,106,0.12); color: var(--danger); border: 1px solid rgba(255,79,106,0.3); }
  .sr-verdict.push { background: rgba(255,255,255,0.06); color: var(--text-dim); border: 1px solid var(--border); }
  .sr-verdict.nomodel { background: rgba(196,162,75,0.1); color: var(--gold); border: 1px solid rgba(196,162,75,0.25); }

  /* DEEP DIVE */
  .deep-section {
    background: rgba(255,79,106,0.04);
    border: 1px solid rgba(255,79,106,0.2);
    border-radius: 4px;
    padding: 18px;
    margin-bottom: 20px;
  }
  .deep-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--danger);
    margin-bottom: 6px;
  }
  .deep-headline {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }

  .pitch-seq {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 12px;
  }
  .pitch-seq-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 10px;
    background: rgba(255,255,255,0.03);
    border-radius: 3px;
    border: 1px solid var(--border);
  }
  .seq-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: var(--text-dim);
    width: 16px;
    flex-shrink: 0;
  }
  .seq-pitch {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--cream);
    width: 130px;
    flex-shrink: 0;
  }
  .seq-result {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    flex: 1;
  }
  .seq-velo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: var(--text-dim);
    width: 55px;
    text-align: right;
    flex-shrink: 0;
  }
  .seq-note {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 10px;
    font-style: italic;
    color: var(--gold);
    width: 160px;
    text-align: right;
    flex-shrink: 0;
  }

  .insight-box {
    background: rgba(196,162,75,0.07);
    border: 1px solid rgba(196,162,75,0.22);
    border-radius: 3px;
    padding: 12px 14px;
    margin-top: 14px;
    font-size: 12px;
    line-height: 1.65;
    color: var(--cream);
  }
  .insight-box strong { color: var(--gold); font-weight: 600; }

  .success-section {
    background: rgba(45,212,160,0.04);
    border: 1px solid rgba(45,212,160,0.2);
    border-radius: 4px;
    padding: 18px;
    margin-bottom: 20px;
  }
  .success-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--success);
    margin-bottom: 6px;
  }
  .success-headline {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }

  .stat-inline {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .stat-chip {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 6px 12px;
    text-align: center;
  }
  .stat-chip-val {
    font-family: 'Oswald', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--success);
    display: block;
    line-height: 1;
  }
  .stat-chip-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 3px;
    display: block;
  }

  .model-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }
  .ms-box {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px;
    text-align: center;
  }
  .ms-val {
    font-family: 'Oswald', sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    display: block;
    margin-bottom: 4px;
  }
  .ms-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .footer {
    text-align: center;
    padding: 14px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    border-top: 1px solid var(--border);
  }
</style>
</head>
