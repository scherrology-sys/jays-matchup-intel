<script>
function switchTab(i) {
  document.querySelectorAll('.tab').forEach((t,j) => t.classList.toggle('active', i===j));
  document.querySelectorAll('.panel').forEach((p,j) => p.classList.toggle('active', i===j));
}

const PITCH_COLORS = {
  '4-Seam Fastball': '#E8002D',
  'Sinker':          '#f4b942',
  'Sweeper':         '#2dd4a0',
  'Split-Finger':    '#7ab8f5',
  'Cutter':          '#c084fc',
  'Curveball':       '#fb923c'
};

// ============================================================
// TAB 1: ARSENAL BARS
// ============================================================
const arsenalData = [
  { name: 'Split-Finger',    pred: 23.5, actual: 20.8, veloPred: 87.3, veloAct: 88.0 },
  { name: 'Sweeper',         pred: 19.8, actual:  8.3, veloPred: 83.6, veloAct: 84.5 },
  { name: '4-Seam Fastball', pred: 18.9, actual: 30.6, veloPred: 92.7, veloAct: 93.1 },
  { name: 'Sinker',          pred: 16.1, actual: 15.3, veloPred: 92.9, veloAct: 93.1 },
  { name: 'Cutter',          pred: 12.0, actual: 20.8, veloPred: 88.2, veloAct: 89.3 },
  { name: 'Curveball',       pred:  9.7, actual:  4.2, veloPred: 78.2, veloAct: 79.8 }
];

function buildArsenal() {
  const container = document.getElementById('arsenalRows');
  const maxVal = 35;
  arsenalData.forEach(p => {
    const color = PITCH_COLORS[p.name] || '#666';
    const delta = (p.actual - p.pred).toFixed(1);
    const deltaColor = Math.abs(p.actual - p.pred) >= 8
      ? (p.actual > p.pred ? 'var(--success)' : 'var(--danger)')
      : 'var(--text-dim)';
    const sign = delta > 0 ? '+' : '';

    const row = document.createElement('div');
    row.className = 'arsenal-row';
    row.innerHTML = `
      <div class="ar-name">${p.name}</div>
      <div class="ar-bars">
        <div class="ar-bar-row">
          <div class="ar-bar-lbl">Proj</div>
          <div class="ar-bar-track">
            <div class="ar-bar-fill" style="width:${p.pred/maxVal*100}%;background:rgba(255,255,255,0.25);"></div>
          </div>
          <div class="ar-pct" style="color:var(--text-dim);">${p.pred}%</div>
        </div>
        <div class="ar-bar-row">
          <div class="ar-bar-lbl">Actual</div>
          <div class="ar-bar-track">
            <div class="ar-bar-fill" style="width:${p.actual/maxVal*100}%;background:${color};"></div>
          </div>
          <div class="ar-pct" style="color:${color};">${p.actual}%</div>
        </div>
      </div>
      <div class="ar-delta" style="color:${deltaColor};">${sign}${delta}%</div>
    `;
    container.appendChild(row);
  });
}

// ============================================================
// TAB 2: SCORECARD ROWS
// ============================================================
const scorecardData = [
  { name: 'Springer, G.',   pred: 0.404, actual: 1.050, outcomes: 'HR, field out',        verdict: 'win'     },
  { name: 'Guerrero Jr., V.', pred: 0.382, actual: 0.000, outcomes: 'K, field out',       verdict: 'miss'    },
  { name: 'Barger, A.',     pred: 0.353, actual: 0.000, outcomes: 'K, field out',         verdict: 'miss'    },
  { name: 'Varsho, D.',     pred: 0.342, actual: 0.000, outcomes: 'field out, K',         verdict: 'miss'    },
  { name: 'Kirk, A.',       pred: 0.341, actual: 0.348, outcomes: 'field out, walk',      verdict: 'win'     },
  { name: 'Sánchez, J.',    pred: 0.312, actual: 0.444, outcomes: 'field out, single',    verdict: 'win'     },
  { name: 'Clement, E.',    pred: 0.305, actual: 0.000, outcomes: 'field out, field out', verdict: 'miss'    },
  { name: 'Giménez, A.',    pred: 0.289, actual: 0.000, outcomes: 'field out, field out', verdict: 'miss'    },
  { name: 'Okamoto, K.',    pred: null,  actual: 0.348, outcomes: 'walk, K',              verdict: 'nomodel' }
];

function buildScorecard() {
  const container = document.getElementById('scorecardRows');
  const maxWoba = 1.1;

  scorecardData.forEach(d => {
    const row = document.createElement('div');
    row.className = `score-row ${d.verdict}`;

    const verdictLabels = { win: 'Called', miss: 'Miss', push: 'Push', nomodel: 'No Model' };
    const actualColor = d.verdict === 'win' ? 'var(--success)' : d.verdict === 'miss' ? 'var(--danger)' : 'var(--text-dim)';
    const deltaStr = d.pred !== null
      ? (d.actual - d.pred >= 0 ? '+' : '') + (d.actual - d.pred).toFixed(3)
      : 'N/A';
    const deltaColor = d.pred !== null
      ? (d.actual - d.pred > 0 ? 'var(--success)' : d.actual - d.pred < -0.05 ? 'var(--danger)' : 'var(--text-dim)')
      : 'var(--gold)';

    row.innerHTML = `
      <div class="sr-name">${d.name}</div>
      <div class="sr-outcomes">${d.outcomes}</div>
      <div class="sr-bar-track">
        ${d.pred !== null ? `<div class="sr-bar-pred" style="width:${d.pred/maxWoba*100}%;background:rgba(255,255,255,0.4);"></div>` : ''}
        <div class="sr-bar-actual" style="width:${d.actual/maxWoba*100}%;background:${actualColor};"></div>
      </div>
      <div class="sr-woba-pred" style="color:var(--text-dim);">${d.pred !== null ? d.pred.toFixed(3) : 'N/A'}</div>
      <div class="sr-arrow">→</div>
      <div class="sr-woba-actual" style="color:${actualColor};">${d.actual.toFixed(3)}</div>
      <div class="sr-delta" style="color:${deltaColor};">${deltaStr}</div>
      <div class="sr-verdict ${d.verdict}">${verdictLabels[d.verdict]}</div>
    `;
    container.appendChild(row);
  });
}

// ============================================================
// TAB 3: PITCH SEQUENCES
// ============================================================
const vladPA1 = [
  { pitch: 'Split-Finger',    result: 'Called Strike',    velo: '85.0 mph', note: '' },
  { pitch: 'Sinker',          result: 'Foul',             velo: '91.2 mph', note: '112.5 mph EV, hit it hard' },
  { pitch: '4-Seam Fastball', result: 'Ball',             velo: '91.5 mph', note: '' },
  { pitch: 'Sweeper',         result: 'Ball',             velo: '85.3 mph', note: '' },
  { pitch: 'Sweeper',         result: 'Ball',             velo: '84.2 mph', note: '' },
  { pitch: '4-Seam Fastball', result: 'Swinging Strike K', velo: '94.3 mph', note: 'Fastball up, off-script closer' }
];
const vladPA2 = [
  { pitch: 'Cutter', result: 'Field Out (weak contact)', velo: '90.0 mph', note: 'Ground ball, 15 ft' }
];

function buildSeq(data, containerId) {
  const container = document.getElementById(containerId);
  data.forEach((p, i) => {
    const color = PITCH_COLORS[p.pitch] || '#aaa';
    const isKey = p.note !== '';
    const row = document.createElement('div');
    row.className = 'pitch-seq-row';
    row.style.borderColor = isKey ? 'rgba(255,255,255,0.15)' : 'var(--border)';
    row.innerHTML = `
      <div class="seq-num" style="color:var(--text-dim);">${i+1}</div>
      <div class="seq-pitch">
        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${color};margin-right:5px;vertical-align:middle;"></span>
        ${p.pitch}
      </div>
      <div class="seq-result" style="color:${p.result.includes('Strike') || p.result.includes('K') ? 'var(--danger)' : p.result === 'Ball' ? 'var(--text-dim)' : 'var(--cream)'};">${p.result}</div>
      <div class="seq-velo">${p.velo}</div>
      <div class="seq-note">${p.note}</div>
    `;
    container.appendChild(row);
  });
}

// ============================================================
// ZONE HEAT MAPS
// Zone order display (top to bottom, pitcher POV): 7,8,9 / 4,5,6 / 1,2,3
// ============================================================
const zoneOrder = [7, 8, 9, 4, 5, 6, 1, 2, 3];

const zoneRHHProj2025    = { 1:24, 2:43, 3:49, 4:57, 5:91, 6:114, 7:38, 8:79, 9:88 };
const zoneRHHTonight     = { 2:2,  3:3,  4:1,  5:3,  6:5,  7:1,   8:1,  9:2       };
const zoneLHHProj2025    = { 1:51, 2:61, 3:31, 4:106, 5:80, 6:65, 7:122, 8:90, 9:51 };
const zoneLHHTonight     = { 1:2,  2:1,  4:2,  5:1,   6:4,  7:2,  8:4,   9:1       };

function buildZoneGrid(data, containerId) {
  const container = document.getElementById(containerId);
  const counts = zoneOrder.map(z => data[z] || 0);
  const maxCount = Math.max(...counts, 1);

  counts.forEach(c => {
    const intensity = c / maxCount;
    const cell = document.createElement('div');
    cell.style.cssText = `
      height: 56px;
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(${Math.round(3 + intensity*229)}, ${Math.round(62 + intensity*(intensity>0.5?-40:80))}, ${Math.round(126 + intensity*(intensity>0.5?-126:0))}, ${0.25 + intensity*0.65});
      color: ${intensity > 0.45 ? '#fff' : 'rgba(255,255,255,0.5)'};
    `;
    cell.textContent = c > 0 ? c : '';
    container.appendChild(cell);
  });
}

// ============================================================
// INIT
// ============================================================
buildArsenal();
buildScorecard();
buildSeq(vladPA1, 'vladSeq1');
buildSeq(vladPA2, 'vladSeq2');
buildZoneGrid(zoneRHHProj2025, 'zoneRHHProj');
buildZoneGrid(zoneRHHTonight,  'zoneRHHActual');
buildZoneGrid(zoneLHHProj2025, 'zoneLHHProj');
buildZoneGrid(zoneLHHTonight,  'zoneLHHActual');
</script>
